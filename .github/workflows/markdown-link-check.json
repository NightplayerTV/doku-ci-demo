{
    "ignorePatterns": [
        {
            "pattern": "http://localhost"
        }
    ],
    "replacementPatterns": [
        {
            "pattern": "/",
            "replacement": "{{BASEURL}}/"
        }
    ],
    "timeout": "10s",
    "retryOn429": true,
    "retryCount": 3,
    "aliveStatusCodes": [200, 206]
}